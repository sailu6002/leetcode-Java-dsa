class Solution {
    public int subarraySum(int[] nums, int k) {
        int current_sum=0;
        int max_sum=0;
        Map<Integer, Integer>presum=new HashMap<>();
        presum.put(0,1);
        for (int i=0;i<nums.length;i++){
            current_sum+=nums[i];
            if(presum.containsKey(current_sum-k)){
                max_sum+=presum.get(current_sum-k);

            }
            presum.put(current_sum,presum.getOrDefault(current_sum,0)+1);
            
            
        }
        return max_sum;
        
    }
}
