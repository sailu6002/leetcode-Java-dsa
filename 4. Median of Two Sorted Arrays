class Solution {
    public double findMedianSortedArrays(int[] nums1, int[] nums2) {
        int n1=nums1.length;
        int n2=nums2.length;
        int[] merge=new int[n1+n2];
        for (int i=0;i<n1;i++){
            merge[i]=nums1[i];
        }
        for (int i=0;i<n2;i++){
            merge[n1+i]=nums2[i];
        }
        Arrays.sort(merge);
        int n=merge.length;
        if(n%2==1){
            return merge[n/2];
        }
        else{
            return (merge[n/2-1]+merge[n/2])/2.0;
        }
    }
}
